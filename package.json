{
  "name": "emberveil-online",
  "version": "0.1.0",
  "private": true,
  "description": "Original desktop 2D online RPG monorepo",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "asset:inventory": "tsx scripts/inventory-assets.ts",
    "asset:manifest": "tsx scripts/generate-asset-manifests.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "smoke:server": "node scripts/smoke-check.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
